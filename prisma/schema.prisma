generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection — runtime queries
  directUrl = env("DIRECT_URL")   // unpooled — migrations only
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  CREATOR
  ADMIN
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

// Tracks a Collaborator account's path to becoming an active CREATOR.
//   NONE     — a plain buyer account, never applied
//   PENDING  — registered as Collaborator, awaiting admin approval
//   APPROVED — admin approved; the user's role is now CREATOR
//   REJECTED — admin declined the collaborator application
enum CreatorStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum AssetStatus {
  PENDING
  APPROVED
  REJECTED
  // Admin can ask a creator to revise without outright rejecting. The
  // asset is hidden from the public marketplace (same as REJECTED) but
  // the creator's My-Assets view surfaces the admin's note prominently
  // so they know what to change. On the creator's next save the edit
  // flow flips status back to PENDING for re-review.
  NEEDS_IMPROVEMENT
}

enum FileType {
  MODEL_3D
  TEXTURE
  HDRI
  MATERIAL
  PLUGIN
  IMAGE_2D
  LOTTIE
  SVG_ICON
}

enum LicenseType {
  STANDARD
  EXTENDED
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum NotificationType {
  ASSET_APPROVED
  ASSET_REJECTED
  ASSET_NEEDS_IMPROVEMENT
  SALE
  PURCHASE
  PAYOUT_PROCESSING
  PAYOUT_PAID
  PAYOUT_FAILED
  KYC_VERIFIED
  KYC_REJECTED
  CREATOR_APPROVED
  CREATOR_REJECTED
  REVIEW
  WELCOME
}

// ─── Auth Models (required by @auth/prisma-adapter v2) ────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // Extended profile
  avatarKey    String? // R2 key for custom uploaded avatar
  passwordHash String?
  bio          String?
  website      String?

  role    Role @default(USER)
  balance Int  @default(0) // stored in INR paise

  // Collaborator application state. PENDING accounts keep role USER (so they
  // can't upload) until an admin approves and promotes them to CREATOR.
  creatorStatus    CreatorStatus @default(NONE)
  creatorDecidedAt DateTime?

  // ─── Collaborator application materials ──────────────────────────────
  // Captured on the /dashboard/become-creator submit so admins reviewing
  // /admin/creators have actual portfolio evidence to judge against.
  // Empty / null on legacy applications submitted before this surface
  // existed.
  creatorPortfolioUrl String? // external portfolio (Behance, ArtStation, etc.)
  creatorDemoNote     String? @db.Text // 50-2000 char self-introduction
  creatorSampleKeys   String[] @default([]) // up to 3 public R2 URLs

  // Legal — proof that the user accepted Terms & Privacy at registration.
  acceptedTermsAt DateTime?

  // KYC / Legal — sensitive PII, accessed only by the user themselves and
  // admins. Aadhaar/PAN numbers stored plaintext for MVP; encrypt-at-rest
  // before going live with real users.
  kycStatus        KycStatus @default(UNVERIFIED)
  legalName        String?
  aadhaarNumber    String?   // 12 digits
  aadhaarKey       String?   // R2 key — front of Aadhaar card
  aadhaarBackKey   String?   // R2 key — back of Aadhaar card
  panNumber        String?   // 10 chars (e.g. ABCDE1234F)
  panKey           String?   // R2 key — PAN card image
  bankAccountName  String?   // name on bank account (must match legal name)
  bankAccount      String?
  bankIfsc         String?
  bankName         String?
  kycSubmittedAt   DateTime?
  kycVerifiedAt    DateTime?
  kycRejectionNote String?

  // RazorpayX caching — created on first payout, reused on subsequent ones.
  // Avoids hitting Razorpay's contact/fund_account rate limits and keeps the
  // payout API call to a single POST.
  razorpayContactId     String?
  razorpayFundAccountId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  assets        Asset[]
  purchases     Purchase[]     @relation("BuyerPurchases")
  payouts       Payout[]
  likes         AssetLike[]
  reviews       Review[]
  adminLogs     AdminLog[]
  notifications Notification[]

  @@index([email])
  @@index([role])
  @@index([kycStatus])
  @@index([creatorStatus])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Business Models ─────────────────────────────────────────────────────

model Asset {
  id          String      @id @default(cuid())
  title       String
  description String
  category    String
  // Optional refined bucket under the main category. Per-category list
  // lives in lib/mock/assets.ts → SUBCATEGORIES; validated server-side
  // at upload time. Null on legacy uploads and on assets where no
  // sub-category fits.
  subcategory String?
  tags        String[]    @default([])
  fileType    FileType
  license     LicenseType @default(STANDARD)

  // R2 keys — never expose directly, always generate signed URLs
  fileKey    String // actual downloadable file (primary format)
  previewKey String // thumbnail / preview image
  modelKey   String? // .glb / .gltf for in-browser 3D preview

  // Lottie bundle companion files. When fileType = LOTTIE and a creator
  // uploads alongside formats, these store the GIF/MP4 keys so downloads
  // can return a multi-file ZIP. Null for non-LOTTIE assets and for Lottie
  // uploads with no companion formats.
  lottieGifKey String?
  lottieMp4Key String?

  // 3D model bundle companion files. When fileType = MODEL_3D and the
  // creator ships alternate formats (engine-specific exports), these
  // hold the private R2 keys for each. The download endpoint serves
  // them when ?format=fbx|obj|usdz|blend|png is requested. Null
  // otherwise.
  //
  //   modelBlendKey — the Blender source (.blend) for editors that
  //     want to remix the asset rather than just consume the export.
  //   modelPngKey   — a rendered PNG (typically the buyer-facing 2D
  //     thumbnail for icon-style 3D assets, or a hero render for full
  //     models).
  modelFbxKey   String?
  modelObjKey   String?
  modelUsdzKey  String?
  modelBlendKey String?
  modelPngKey   String?

  // Icon-pack support: a 3D-icons listing can ship as a bundle of many
  // .glb files (one per icon), each individually previewable on the
  // detail page's slider. When packItems exists the listing is a pack
  // and the download endpoint returns a ZIP of every item; when empty
  // the Asset behaves as a normal single-file 3D upload.
  packItems     AssetPackItem[]

  price  Int @default(0) // INR paise; 0 = free

  status        AssetStatus @default(PENDING)
  rejectionNote String?

  // Metrics
  downloads    Int @default(0)
  likes        Int @default(0)

  // Review aggregates — denormalized so asset-card lists don't each run an
  // aggregate query. Recomputed whenever a review is created/edited/deleted.
  avgRating   Float @default(0)
  reviewCount Int   @default(0)

  // Metadata
  polygonCount  Int?
  fileSizeBytes Int?
  dimensions    String? // e.g. "4096x4096"

  uploaderId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploader   User        @relation(fields: [uploaderId], references: [id])
  purchases  Purchase[]
  assetLikes AssetLike[]
  reviews    Review[]

  // Composite indexes targeting the actual browse query patterns —
  // the marketplace filters all hit `status = APPROVED` first.
  @@index([status, category, createdAt(sort: Desc)])
  @@index([status, category, subcategory])
  @@index([status, downloads(sort: Desc)])
  @@index([status, price])
  @@index([status, fileType, createdAt(sort: Desc)])
  @@index([uploaderId])
  @@index([tags], type: Gin) // Postgres GIN for `tags has` lookups
}

/// Sub-asset row inside an icon-pack listing. Each row is one .glb
/// file (one icon) the buyer can preview individually in the detail
/// page's slider and receive in the downloaded ZIP. Cascades on the
/// parent Asset's deletion so cleaning up the listing also wipes its
/// pack manifest.
model AssetPackItem {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  name         String // shown under the slider thumb; auto-derived from filename at upload time
  fileKey      String // private R2 key for the .glb (the file the buyer downloads)
  modelKey     String // public R2 URL for the in-browser viewer
  displayOrder Int    @default(0)

  fileSizeBytes Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([assetId, displayOrder])
}

model AssetLike {
  id      String @id @default(cuid())
  userId  String
  assetId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
  @@index([assetId])
  @@index([userId])
}

// A buyer's star rating + optional written review of an asset they own.
// One review per user per asset.
model Review {
  id        String   @id @default(cuid())
  assetId   String
  userId    String
  rating    Int // 1-5 stars
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
  @@index([assetId])
}

model Purchase {
  id             String         @id @default(cuid())
  buyerId        String
  assetId        String
  amount         Int // INR paise (total charged)
  platformFee    Int // INR paise
  creatorEarning Int // INR paise
  licenseKey     String         @unique @default(cuid()) // proof of purchase

  razorpayOrderId   String?
  razorpayPaymentId String?
  status            PurchaseStatus @default(PENDING)

  createdAt DateTime @default(now())

  buyer User  @relation("BuyerPurchases", fields: [buyerId], references: [id])
  asset Asset @relation(fields: [assetId], references: [id])

  @@unique([buyerId, assetId]) // one purchase per user per asset
  @@index([buyerId])
  @@index([assetId])
  @@index([status])
  @@index([razorpayOrderId])
}

model Payout {
  id        String       @id @default(cuid())
  creatorId String
  amount    Int // INR paise
  status    PayoutStatus @default(PENDING)

  // RazorpayX transaction ID — set when admin triggers the actual payout
  // via the RazorpayX API. NULL means the payout is still queued in our DB.
  razorpayPayoutId String?
  // For manual payouts: the bank UTR / IMPS reference the admin records
  // when marking the payout PAID. Surfaced to the creator so they can
  // reconcile it against their bank statement.
  transactionRef   String?
  failureReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User @relation(fields: [creatorId], references: [id])

  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
  @@index([razorpayPayoutId]) // webhook looks up payouts by RazorpayX ID
}

// In-app notifications — one row per delivered notification to one user.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String? // in-app path to open when the notification is clicked
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The bell badge query filters by (userId, read); the list query orders
  // by (userId, createdAt). Both are covered here.
  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}

// Polymorphic audit trail — targetType tells you what targetId refers to
model AdminLog {
  id         String  @id @default(cuid())
  adminId    String
  action     String // e.g. "APPROVE_ASSET", "REJECT_ASSET", "BAN_USER"
  targetId   String // ID of the affected entity
  targetType String // "ASSET" | "USER" | "PAYOUT"
  note       String?
  metadata   Json?

  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetId])
  @@index([targetType])
  @@index([createdAt])
}
